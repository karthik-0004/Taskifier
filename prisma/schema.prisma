generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  MANAGER
  EMPLOYEE
}

enum ProjectStatus {
  PLANNING
  NOT_STARTED
  IN_PROGRESS
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum ProjectPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ProjectCategory {
  WEB_APPLICATION
  MOBILE_APP
  AI_ML
  DEVOPS
  DATABASE
  CLOUD
  OTHER
}

enum SessionSource {
  VSCODE
  CURSOR
  OTHER
}

enum ActivityType {
  COMMIT
  BRANCH_SWITCH
  PR_OPENED
  FILE_EDIT
}

enum SummaryStatus {
  DRAFT
  APPROVED
  REJECTED
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  passwordHash  String
  name          String
  phoneNumber   String?
  position      String?
  profilePicture String?
  role          Role
  githubUsername String?
  resetToken    String?
  resetTokenExpiry DateTime?
  skills        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projectAssignments   ProjectAssignment[]
  managedProjects      Project[]           @relation("ProjectManager")
  leadProjects         Project[]           @relation("TeamLead")
  createdProjects      Project[]           @relation("ProjectCreator")
  githubConnection     GithubConnection?
  workSessions         WorkSession[]
  dailySummaries       DailySummary[]
  weeklyReports        WeeklyReport[]
  attendance           Attendance[]
}

model Project {
  id          String        @id @default(uuid())
  name        String
  code        String        @unique
  description String?
  category    ProjectCategory?
  clientName  String?

  startDate       DateTime?
  expectedEndDate DateTime?
  priority        ProjectPriority?
  status          ProjectStatus     @default(NOT_STARTED)

  projectManagerId String?
  projectManager   User?  @relation("ProjectManager", fields: [projectManagerId], references: [id], onDelete: SetNull)
  teamLeadId       String?
  teamLead         User?  @relation("TeamLead", fields: [teamLeadId], references: [id], onDelete: SetNull)
  maxTeamSize      Int?

  estimatedDuration Int?
  budget           Float?
  techStack        String?
  requiredSkills   String?
  repoUrl          String?
  docsUrl          String?
  tags             String?

  managerId String
  manager   User   @relation("ProjectCreator", fields: [managerId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignments ProjectAssignment[]
  workSessions WorkSession[]
}

model ProjectAssignment {
  id          String   @id @default(uuid())
  userId      String
  projectId   String
  role        String   @default("OTHER")
  workload    Int?
  joiningDate DateTime?

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
}

model GithubConnection {
  id            String   @id @default(uuid())
  userId        String   @unique
  accessToken   String
  githubUsername String
  connectedAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WorkSession {
  id        String        @id @default(uuid())
  userId    String
  projectId String?
  startedAt DateTime
  endedAt   DateTime?
  source    SessionSource

  user    User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  activityEvents ActivityEvent[]
}

model ActivityEvent {
  id        String       @id @default(uuid())
  sessionId String
  type      ActivityType
  payload   Json
  timestamp DateTime     @default(now())

  session WorkSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model DailySummary {
  id                 String        @id @default(uuid())
  userId             String
  date               DateTime
  aiGeneratedContent String
  editedContent      String?
  status             SummaryStatus
  approvedAt         DateTime?
  createdAt          DateTime      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model WeeklyReport {
  id          String   @id @default(uuid())
  userId      String
  weekStart   DateTime
  content     String
  generatedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekStart])
}

model Attendance {
  id         String    @id @default(uuid())
  userId     String
  date       DateTime
  checkInAt  DateTime?
  checkOutAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}
